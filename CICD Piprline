Jenkinsfile (Real DevOps Pipeline)
pipeline {
    agent any

    environment {
        AWS_REGION = "ap-south-1"
        IMAGE_NAME = "my-app"
        ACCOUNT_ID = "<your-account-id>"
        ECR_REPO = "${ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${IMAGE_NAME}"
    }

    stages {

        // ==============================
        // 🔨 BUILD DOCKER IMAGE
        // ==============================
        stage('Build') {
            steps {
                sh 'docker build -t $IMAGE_NAME:$BUILD_NUMBER .'
            }
        }

        // ==============================
        // 🔐 LOGIN TO ECR
        // ==============================
        stage('Login to ECR') {
            steps {
                sh '''
                aws ecr get-login-password --region $AWS_REGION | \
                docker login --username AWS --password-stdin $ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com
                '''
            }
        }

        // ==============================
        // 🚀 PUSH IMAGE TO ECR
        // ==============================
        stage('Push Image') {
            steps {
                sh '''
                docker tag $IMAGE_NAME:$BUILD_NUMBER $ECR_REPO:$BUILD_NUMBER
                docker push $ECR_REPO:$BUILD_NUMBER
                '''
            }
        }

        // ==============================
        // ☸️ DEPLOY TO EKS USING HELM
        // ==============================
        stage('Deploy to EKS') {
            steps {
                sh '''
                aws eks update-kubeconfig --region $AWS_REGION --name my-cluster

                helm upgrade --install my-app ./helm/my-app \
                --set image.repository=$ECR_REPO \
                --set image.tag=$BUILD_NUMBER
                '''
            }
        }
    }
}





