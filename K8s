# =========================
# 🔥 ADVANCED DEBUGGING COMMANDS (REAL PRODUCTION)
# =========================

# -------------------------
# 📌 POD DEEP DEBUGGING
# -------------------------

kubectl get pod <pod-name> -o yaml
# Purpose: Full pod definition (actual running state)
# When: Need exact config, env vars, volume mounts

kubectl get pod <pod-name> -o jsonpath='{.status.containerStatuses[*].state}'
# Purpose: Get container state (waiting/running/terminated)
# When: Debug crash reasons

kubectl get pod <pod-name> -o jsonpath='{.status.containerStatuses[*].lastState}'
# Purpose: Previous container state
# When: CrashLoopBackOff root cause

kubectl describe pod <pod-name> | grep -i error
# Purpose: Filter only errors
# When: Faster debugging


# -------------------------
# 📌 IMAGE & CONTAINER ISSUES
# -------------------------

kubectl describe pod <pod-name> | grep -i image
# Purpose: Check image pull issues
# When: ImagePullBackOff

kubectl get events | grep -i "pull"
# Purpose: Image pull failures
# When: Registry/auth issue


# -------------------------
# 📌 NETWORK DEBUGGING
# -------------------------

kubectl exec -it <pod-name> -- curl http://<service-name>:<port>
# Purpose: Test service connectivity
# When: Service not reachable

kubectl exec -it <pod-name> -- ping <service-name>
# Purpose: Check DNS/network
# When: Network issue

kubectl exec -it <pod-name> -- nslookup <service-name>
# Purpose: DNS resolution
# When: Service name not resolving

kubectl run debug-pod --image=busybox -it --rm -- sh
# Purpose: Temporary debug pod
# When: Test network from cluster


# -------------------------
# 📌 SERVICE DEBUGGING
# -------------------------

kubectl get svc <service-name> -o yaml
# Purpose: Full service config
# When: Service misconfiguration

kubectl get endpoints <service-name>
# Purpose: Check connected pods
# When: No traffic reaching pods

kubectl describe svc <service-name>
# Purpose: Check selector & ports
# When: Routing issue


# -------------------------
# 📌 NODE LEVEL DEBUGGING
# -------------------------

kubectl describe node <node-name> | grep -i pressure
# Purpose: Check memory/cpu/disk pressure
# When: Pod not scheduling

kubectl top node
# Purpose: Resource usage
# When: High load

kubectl get nodes -o wide
# Purpose: Node details
# When: Node identification


# -------------------------
# 📌 SCHEDULING ISSUES
# -------------------------

kubectl describe pod <pod-name> | grep -i "Insufficient"
# Purpose: Resource shortage
# When: Pending pods

kubectl describe pod <pod-name> | grep -i taint
# Purpose: Taints issue
# When: Pod not scheduling

kubectl get nodes --show-labels
# Purpose: Node labels
# When: NodeSelector mismatch


# -------------------------
# 📌 LOGGING ADVANCED
# -------------------------

kubectl logs -f <pod-name>
# Purpose: Live logs (streaming)
# When: Real-time debugging

kubectl logs --tail=100 <pod-name>
# Purpose: Last 100 lines
# When: Quick check

kubectl logs --since=10m <pod-name>
# Purpose: Logs from last 10 mins
# When: Recent issue


# -------------------------
# 📌 MULTI-CONTAINER DEBUGGING
# -------------------------

kubectl describe pod <pod-name> | grep -i container
# Purpose: Container info
# When: Multiple containers

kubectl logs <pod-name> -c <container-name>
# Purpose: Specific container logs
# When: Sidecar issues


# -------------------------
# 📌 CONFIG DEBUGGING
# -------------------------

kubectl get configmap <name> -o yaml
# Purpose: View config values
# When: Wrong config issue

kubectl exec -it <pod-name> -- printenv
# Purpose: Check env variables
# When: ConfigMap/Secret issue


# -------------------------
# 📌 STORAGE DEBUGGING
# -------------------------

kubectl get pvc
# Purpose: Check PVC status
# When: Volume issue

kubectl describe pvc <name>
# Purpose: PVC details
# When: Pending storage

kubectl describe pod <pod-name> | grep -i mount
# Purpose: Volume mount errors
# When: Storage issues


# -------------------------
# 📌 DEPLOYMENT DEBUGGING
# -------------------------

kubectl rollout status deployment <name>
# Purpose: Check deployment progress
# When: Deployment stuck

kubectl rollout pause deployment <name>
# Purpose: Pause rollout
# When: Debug during deploy

kubectl rollout resume deployment <name>
# Purpose: Resume rollout
# When: Continue after fix


# -------------------------
# 📌 CLUSTER DEBUGGING
# -------------------------

kubectl cluster-info dump
# Purpose: Full cluster state dump
# When: Deep debugging

kubectl get componentstatuses
# Purpose: Check control plane components
# When: Cluster issue


# -------------------------
# 📌 PERFORMANCE DEBUGGING
# -------------------------

kubectl top pod --containers
# Purpose: Per container usage
# When: High CPU/memory

kubectl describe pod <pod-name> | grep -i cpu
# Purpose: CPU limits/requests
# When: CPU issues


# -------------------------
# 📌 CLEANUP / FORCE DEBUG
# -------------------------

kubectl delete pod <pod-name> --force --grace-period=0
# Purpose: Force delete stuck pod
# When: Pod stuck in Terminating

kubectl get pod <pod-name> -w
# Purpose: Watch live changes
# When: Debug real-time state changes
