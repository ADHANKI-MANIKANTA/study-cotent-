# =========================
# 🔰 BASIC COMMANDS
# =========================

kubectl get pods
# Purpose: List all pods
# When: First step to check pod status

kubectl get pods -o wide
# Purpose: Show pod IP, node details
# When: Need node/IP info

kubectl get all
# Purpose: List all resources (pods, svc, deployments)
# When: Quick cluster overview

kubectl get pods -n <namespace>
# Purpose: List pods in specific namespace
# When: Working in multi-env (dev/prod)

kubectl get ns
# Purpose: List namespaces
# When: Identify environments


# =========================
# 🔍 DESCRIBE & EVENTS
# =========================

kubectl describe pod <pod-name>
# Purpose: Detailed pod info + events
# When: Pod not starting / failing

kubectl describe node <node-name>
# Purpose: Node health, resource usage
# When: Pods not scheduling

kubectl get events
# Purpose: Cluster events (errors/warnings)
# When: Hidden issues (image pull, scheduling)


# =========================
# 📜 LOGS
# =========================

kubectl logs <pod-name>
# Purpose: View application logs
# When: App errors / crashes

kubectl logs <pod-name> -c <container-name>
# Purpose: Logs of specific container
# When: Multi-container pod

kubectl logs <pod-name> --previous
# Purpose: Logs before crash
# When: CrashLoopBackOff


# =========================
# 🧠 DEBUGGING (INSIDE POD)
# =========================

kubectl exec -it <pod-name> -- /bin/sh
# Purpose: Access pod shell
# When: Debug inside container

kubectl exec <pod-name> -- ls /app
# Purpose: Run command inside pod
# When: Check files/config


# =========================
# 📊 RESOURCE USAGE
# =========================

kubectl top pod
# Purpose: CPU/Memory usage of pods
# When: High CPU / performance issue

kubectl top node
# Purpose: Node resource usage
# When: Node overloaded


# =========================
# 🔄 DEPLOYMENT COMMANDS
# =========================

kubectl get deployment
# Purpose: List deployments
# When: Check app deployment status

kubectl describe deployment <name>
# Purpose: Deployment details
# When: Deployment issues

kubectl rollout status deployment <name>
# Purpose: Check rollout progress
# When: During deployment

kubectl rollout history deployment <name>
# Purpose: See previous versions
# When: Need rollback info

kubectl rollout undo deployment <name>
# Purpose: Rollback deployment
# When: Bad deployment


# =========================
# 🚫 POD TROUBLESHOOTING
# =========================

kubectl delete pod <pod-name>
# Purpose: Restart pod
# When: Temporary fix / stuck pod

kubectl get pod <pod-name> -o yaml
# Purpose: Full pod config
# When: Deep debugging


# =========================
# 🌐 SERVICE & NETWORK
# =========================

kubectl get svc
# Purpose: List services
# When: Check exposure

kubectl describe svc <service-name>
# Purpose: Service details
# When: Connectivity issue

kubectl get endpoints
# Purpose: Check pod connection to service
# When: Service not routing traffic


# =========================
# 📦 CONFIG & SECRETS
# =========================

kubectl get configmap
# Purpose: List configmaps
# When: Config debugging

kubectl describe configmap <name>
# Purpose: View config values
# When: App config issue

kubectl get secret
# Purpose: List secrets
# When: Secret check

kubectl describe secret <name>
# Purpose: Secret details
# When: Credential issues


# =========================
# ⚙️ YAML & VALIDATION
# =========================

kubectl apply -f file.yaml
# Purpose: Apply config
# When: Deploy resources

kubectl apply -f file.yaml --dry-run=client
# Purpose: Validate YAML
# When: Before deployment

kubectl delete -f file.yaml
# Purpose: Delete resources
# When: Cleanup


# =========================
# 🧱 NODE & SCHEDULING
# =========================

kubectl get nodes
# Purpose: List nodes
# When: Check cluster status

kubectl cordon <node-name>
# Purpose: Mark node unschedulable
# When: Maintenance

kubectl drain <node-name>
# Purpose: Move pods from node
# When: Node shutdown


# =========================
# 🔐 ADVANCED DEBUGGING
# =========================

kubectl get pods --field-selector=status.phase=Pending
# Purpose: Filter pending pods
# When: Scheduling issues

kubectl get pods --sort-by=.metadata.creationTimestamp
# Purpose: Sort pods by time
# When: Recent failures

kubectl get events --sort-by=.metadata.creationTimestamp
# Purpose: Sort events
# When: Timeline debugging

kubectl api-resources
# Purpose: List all resource kinds
# When: Exploring cluster


# =========================
# 🚀 POWER USER COMMANDS
# =========================

kubectl edit deployment <name>
# Purpose: Edit live resource
# When: Quick fixes

kubectl port-forward pod/<pod-name> 8080:80
# Purpose: Access pod locally
# When: Debug API/UI

kubectl proxy
# Purpose: Access Kubernetes API
# When: Internal debugging

kubectl cluster-info
# Purpose: Cluster details
# When: Verify cluster access



